		"$Comments": [
			{
				"$NodeId": "Comment-83e027e5-b0ba-46de-a237-c06091c50b75",
				"$Position": {
					"$x": -4691.9745816949935,
					"$y": -3872.3236514979117
				},
				"$width": 507,
				"$height": 81,
				"$name": "What  is this?",
				"$text": "Height optimisation creates a stable base density field. Each feature (hills, cliffs, etc.) is then shaped independently using curves (normalisation), and finally rebased so it attaches correctly to the terrain surface.",
				"$fontSize": 9
			},
			{
				"$NodeId": "Comment-cf4f09e2-d51f-4bec-803b-ced1198ac234",
				"$Position": {
					"$x": -3882.7106181635986,
					"$y": -3669.4722750067936
				},
				"$width": 376,
				"$height": 114,
				"$name": "What is this?",
				"$text": "This curve defines where the ground is: everything below it is solid and everything above it is air. It uses a very small gap (like 0 to 0.1) so the change happens almost instantly, giving you a clean, sharp surface instead of a soft or messy transition.",
				"$fontSize": 9
			},
			{
				"$NodeId": "Comment-e9825726-6de8-4ace-95fc-10e3a493b65e",
				"$Position": {
					"$x": -2758.3911031672665,
					"$y": -3572.928371398664
				},
				"$width": 178,
				"$height": 96,
				"$name": "Ground Level",
				"$text": "Marks the ground level everything below is solidMarks the ground level everything below is solid",
				"$fontSize": 9

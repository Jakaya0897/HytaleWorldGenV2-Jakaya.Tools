				"$width": 509,
				"$height": 97,
				"$name": "What is this?",
				"$text": "This curve acts as a height mask, controlling where terrain is allowed to be modified: in the middle it allows full modification, while toward the bottom and top it gradually restricts changes, ensuring the ground stays solid below the set value and preventing terrain from extending too high above.",
				"$fontSize": 9
			},
